# Environment: development | production
ENVIRONMENT=development

# JWT
SECRET_KEY=dev-only-insecure-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./app.db

# Bootstrap admin
# Production: python scripts/seed_admin.py --username <name> --password <pass> --confirm
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=dev-only-password

# CORS
# Production: set explicit origins (required); wildcards are rejected
CORS_ORIGINS=http://localhost:3000

# Login rate limiting
# RATELIMIT_ENABLED=true

# Trusted reverse proxies for login rate limiting
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
